{
  "name": "lucky-server",
  "description": "A modular server framework built on Express, designed for flexibility and scalability.",
  "private": true,
  "version": "1.0.1",
  "author": "talkohavy@gmail.com",
  "license": "MIT",
  "keywords": ["lucky", "server", "express", "modules"],
  "exports": {
    ".": {
      "import": {
        "types": "./index.d.ts",
        "default": "./index.esm.mjs"
      },
      "require": {
        "types": "./index.d.ts",
        "default": "./index.cjs.cjs"
      }
    }
  },
  "scripts": {
    "clean": "rm -rf node_modules",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "tsc": "tsc -p tsconfig.json",
    "build": "node ./build.config.mjs",
    "test": "node --test"
  },
  "contributors": [
    {
      "name": "Tal Kohavy",
      "email": "talkohavy@gmail.com",
      "url": "https://github.com/talkohavy"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/talkohavy/lucky-server.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "restricted"
  },
  "bugs": {
    "url": "https://github.com/talkohavy/lucky-server/issues",
    "email": "talkohavy@gmail.com"
  },
  "peerDependencies": {
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.4",
    "@types/express": "^5.0.3",
    "@types/node": "^24.1.0",
    "eslint": "^9.32.0",
    "eslint-plugin-perfectionist": "^4.15.0",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "express": "^5.1.0",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "prettier": "^3.6.2",
    "rollup": "^4.52.4",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0"
  },
  "packageManager": "pnpm@10.15.0"
}
